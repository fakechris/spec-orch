# SpecOrch environment configuration
# Copy this file to .env and fill in your values.
#
# The .env file is auto-loaded by the CLI on startup.
# Variables here map to `api_key_env` / `token_env` in spec-orch.toml.
# ──────────────────────────────────────────────────────────

# ── Linear integration ────────────────────────────────────
# Required for: daemon, promote, run --source linear
# Referenced by: [linear] token_env = "SPEC_ORCH_LINEAR_TOKEN"
SPEC_ORCH_LINEAR_TOKEN=lin_api_xxxxxxxxxxxxxxxxxxxxx

# ── LLM provider (planner / discuss / readiness) ─────────
# Referenced by: [planner] api_key_env = "SPEC_ORCH_LLM_API_KEY"
#                [planner] api_base_env = "SPEC_ORCH_LLM_API_BASE"
# Supports any LiteLLM-compatible provider (Anthropic, OpenAI, MiniMax, etc.)
SPEC_ORCH_LLM_API_KEY=your-api-key-here
SPEC_ORCH_LLM_API_BASE=https://api.anthropic.com

# ── Example: MiniMax (Anthropic-compatible endpoint) ──────
# SPEC_ORCH_LLM_API_KEY=sk-cp-xxxx
# SPEC_ORCH_LLM_API_BASE=https://api.minimaxi.com/anthropic

# ── Example: OpenAI ──────────────────────────────────────
# SPEC_ORCH_LLM_API_KEY=sk-xxxx
# SPEC_ORCH_LLM_API_BASE=https://api.openai.com/v1

# ── LLM reviewer (optional, only when [reviewer] adapter = "llm") ──
# Referenced by: [reviewer] api_key_env, [reviewer] api_base_env
# SPEC_ORCH_LLM_API_BASE_OPENAI=https://api.minimaxi.com/v1

# ── GitHub token (optional — for PR creation via API) ────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
