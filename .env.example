# SpecOrch environment configuration
# Copy this file to .env and fill in your values.

# Linear integration (required for daemon / promote / run --source linear)
SPEC_ORCH_LINEAR_TOKEN=lin_api_xxxxxxxxxxxxxxxxxxxxx

# LLM provider — used by discuss, plan, readiness triage
# Supports any provider via LiteLLM: OpenAI, Anthropic, MiniMax, etc.
MINIMAX_API_KEY=your-api-key-here
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# GitHub token (optional — for PR creation via API instead of gh CLI)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
