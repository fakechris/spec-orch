# SpecOrch environment configuration
# ══════════════════════════════════════════════════════════
# SETUP: cp .env.example .env && $EDITOR .env
#
# This file is auto-loaded by ALL spec-orch commands (daemon, dashboard, etc.)
# No need to manually `export` — just edit .env and restart.
# ══════════════════════════════════════════════════════════

# ── LLM provider (REQUIRED — used by daemon, dashboard, all LLM calls) ──
# This is the MOST IMPORTANT variable. Without it, planning/review/retry
# operations will fail with "litellm.AuthenticationError: Missing API key".
SPEC_ORCH_LLM_API_KEY=your-api-key-here
SPEC_ORCH_LLM_API_BASE=https://api.anthropic.com

# ── Linear integration (required for daemon) ─────────────
SPEC_ORCH_LINEAR_TOKEN=lin_api_xxxxxxxxxxxxxxxxxxxxx

# ── Example: MiniMax (Anthropic-compatible endpoint) ──────
# SPEC_ORCH_LLM_API_KEY=sk-cp-xxxx
# SPEC_ORCH_LLM_API_BASE=https://api.minimaxi.com/anthropic

# ── Example: OpenAI ──────────────────────────────────────
# SPEC_ORCH_LLM_API_KEY=sk-xxxx
# SPEC_ORCH_LLM_API_BASE=https://api.openai.com/v1

# ── LLM reviewer (optional, only when [reviewer] adapter = "llm") ──
# The reviewer reads its own api_key_env / api_base_env from spec-orch.toml.
# Set the env var names that match YOUR [reviewer] config, e.g.:
#   [reviewer] api_key_env = "MY_REVIEW_KEY" → export MY_REVIEW_KEY=sk-xxxx
#   [reviewer] api_base_env = "MY_REVIEW_BASE" → export MY_REVIEW_BASE=https://...

# ── GitHub token (optional — for PR creation via API) ────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
